rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /orders/{orderId} {
      allow create: if true; // In production, refine this with validation
      allow read: if false;
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
